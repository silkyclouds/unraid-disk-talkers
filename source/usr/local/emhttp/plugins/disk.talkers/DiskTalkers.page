<script>
(() => {
  const endpoint = "/plugins/disk.talkers/api/state.php";
  const controlEndpoint = "/plugins/disk.talkers/api/control.php";
  const settingsEndpoint = "/plugins/disk.talkers/api/settings.php";
  const meta = document.getElementById("dt-meta");
  const notices = document.getElementById("dt-notices");
  const spinUpAllButton = document.getElementById("dt-spinup-all");
  const spinDownAllButton = document.getElementById("dt-spindown-all");
  const settingsOpenButton = document.getElementById("dt-settings-open");
  const audit = document.getElementById("dt-audit");
  const auditBody = document.getElementById("dt-audit-body");
  const auditToggle = document.getElementById("dt-audit-toggle");
  const periods = document.getElementById("dt-periods");
  const summary = document.getElementById("dt-summary");
  const root = document.getElementById("dt-root");
  const toast = document.getElementById("dt-toast");
  const modalShell = document.getElementById("dt-modal-shell");
  const modalTitle = document.getElementById("dt-modal-title");
  const modalSubtitle = document.getElementById("dt-modal-subtitle");
  const modalBody = document.getElementById("dt-modal-body");
  const modalClose = document.getElementById("dt-modal-close");
  const settingsShell = document.getElementById("dt-settings-shell");
  const settingsClose = document.getElementById("dt-settings-close");
  const settingsCancel = document.getElementById("dt-settings-cancel");
  const settingsForm = document.getElementById("dt-settings-form");
  const settingsSave = document.getElementById("dt-settings-save");
  const tariffModeInput = document.getElementById("dt-electricity-tariff-mode");
  const singleRateField = document.getElementById("dt-single-rate-field");
  const dualOnlyFields = Array.from(document.querySelectorAll(".dt-dual-only"));
  const tooltip = document.getElementById("dt-tooltip");
  const detailStore = new Map();
  const periodOptions = ["daily", "weekly", "monthly", "yearly"];
  const chartPalette = ["#74b7ff", "#ffb55e", "#8fe388", "#ca9cff", "#6ee0d6", "#ff7d91", "#c4d96f", "#93a7ff"];
  let selectedPeriod = localStorage.getItem("dt-history-period") || "daily";
  let auditOpen = localStorage.getItem("dt-audit-open") === "1";
  let auditCount = 0;
  let currentSettings = null;
  let toastTimer = null;

  function applyHostTheme() {
    const background = getComputedStyle(document.body).backgroundColor || getComputedStyle(document.documentElement).backgroundColor;
    const match = background.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/i);
    if (!match) {
      return;
    }
    const red = Number(match[1]);
    const green = Number(match[2]);
    const blue = Number(match[3]);
    const luminance = ((0.2126 * red) + (0.7152 * green) + (0.0722 * blue)) / 255;
    document.documentElement.classList.toggle("dt-host-light", luminance >= 0.62);
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");
  }

  function iconHtml(icon, title) {
    if (icon && icon.type === "image" && icon.value) {
      return `<span class="dt-icon" title="${escapeHtml(title)}"><img src="${escapeHtml(icon.value)}" alt="${escapeHtml(title)}" onerror="this.onerror=null;this.replaceWith(Object.assign(document.createElement('i'),{className:'fa fa-cube'}));"></span>`;
    }

    const iconClass = icon && icon.value ? icon.value : "fa-cog";
    return `<span class="dt-icon" title="${escapeHtml(title)}"><i class="fa ${escapeHtml(iconClass)}"></i></span>`;
  }

  function renderPathList(paths) {
    if (!paths || !paths.length) {
      return '<div class="dt-empty">-</div>';
    }
    return `<div class="dt-path-list">${paths.map((path) => `<div class="dt-path-item">${escapeHtml(path)}</div>`).join("")}</div>`;
  }

  function periodLabel(period) {
    return ({ daily: "Daily", weekly: "Weekly", monthly: "Monthly", yearly: "Yearly" })[period] || period;
  }

  function renderPeriodButtons(activePeriod) {
    periods.innerHTML = periodOptions.map((period) => `
      <button type="button" class="dt-period-btn ${period === activePeriod ? "active" : ""}" data-period="${escapeHtml(period)}">${escapeHtml(periodLabel(period))}</button>
    `).join("");
  }

  function applyAuditVisibility() {
    auditBody.hidden = !auditOpen;
    const suffix = auditCount ? ` ${auditCount}` : "";
    auditToggle.textContent = auditOpen ? `Hide${suffix}` : `Show${suffix}`;
    auditToggle.classList.toggle("active", auditOpen);
  }

  function showToast(message, tone = "success") {
    if (!toast) {
      return;
    }
    if (toastTimer) {
      window.clearTimeout(toastTimer);
    }
    toast.textContent = message;
    toast.className = `dt-toast ${tone}`;
    toast.hidden = false;
    toastTimer = window.setTimeout(() => {
      toast.hidden = true;
    }, 3200);
  }

  function setButtonBusy(button, busy) {
    if (!button) {
      return;
    }
    button.disabled = busy;
    button.classList.toggle("busy", busy);
  }

  function renderNotices(items) {
    if (!notices) {
      return;
    }
    if (!items.length) {
      notices.hidden = true;
      notices.innerHTML = "";
      return;
    }
    notices.innerHTML = items.map((item) => `
      <div class="dt-notice ${escapeHtml(item.tone || "info")}">${escapeHtml(item.message || "")}</div>
    `).join("");
    notices.hidden = false;
  }

  function applyDependencyBlocked(blocked) {
    spinUpAllButton.disabled = blocked;
    spinDownAllButton.disabled = blocked;
    summary.hidden = blocked;
    audit.hidden = blocked;
    if (blocked) {
      periods.innerHTML = "";
      auditBody.innerHTML = "";
      summary.innerHTML = "";
    }
  }

  function renderDependencyBlocked(payload) {
    const dependency = payload.dependency || {};
    const name = dependency.name || "Python 3 for UNRAID (6.11+)";
    const reason = dependency.reason || "python3 binary not found on the Unraid host";
    const installHint = dependency.install_hint || "Install `Python 3 for UNRAID (6.11+)` from Community Applications, then refresh this page.";
    const supportUrl = dependency.support_url || "";

    const linkHtml = supportUrl
      ? `<a class="dt-action-btn secondary" href="${escapeHtml(supportUrl)}" target="_blank" rel="noopener">Open Python plugin thread</a>`
      : "";

    return `
      <div class="dt-dependency-card">
        <div class="dt-dependency-kicker">Dependency required</div>
        <div class="dt-dependency-title">${escapeHtml(name)}</div>
        <div class="dt-dependency-copy">Disk Talkers needs this dependency before the collector can run on the Unraid host.</div>
        <div class="dt-dependency-reason">Reason: ${escapeHtml(reason)}</div>
        <div class="dt-dependency-actions">
          ${linkHtml}
        </div>
        <div class="dt-dependency-note">${escapeHtml(installHint)} Search for <strong>${escapeHtml(name)}</strong> in Community Applications, install it, then refresh Disk Talkers.</div>
      </div>
    `;
  }

  function confirmDialog(title, text) {
    if (typeof swal === "function") {
      return new Promise((resolve) => {
        swal({
          title,
          text,
          type: "warning",
          html: true,
          showCancelButton: true,
          confirmButtonText: "Proceed",
          cancelButtonText: "Cancel"
        }, resolve);
      });
    }
    return Promise.resolve(window.confirm(text));
  }

  function applyTariffMode(mode) {
    const dual = mode === "dual";
    singleRateField.hidden = dual;
    dualOnlyFields.forEach((field) => {
      field.hidden = !dual;
    });
  }

  function populateSettingsForm(settings) {
    if (!settings || !settingsForm) {
      return;
    }
    settingsForm.elements.poll_interval.value = settings.poll_interval ?? 5;
    settingsForm.elements.recent_window.value = settings.recent_window ?? 300;
    settingsForm.elements.max_talkers.value = settings.max_talkers ?? 5;
    settingsForm.elements.history_sample_interval.value = settings.history_sample_interval ?? 300;
    settingsForm.elements.hdd_power_min_w.value = settings.hdd_power_min_w ?? 6;
    settingsForm.elements.hdd_power_max_w.value = settings.hdd_power_max_w ?? 9;
    settingsForm.elements.currency_symbol.value = settings.currency_symbol ?? "€";
    settingsForm.elements.electricity_tariff_mode.value = settings.electricity_tariff_mode ?? "single";
    settingsForm.elements.electricity_single_rate.value = settings.electricity_single_rate ?? 0;
    settingsForm.elements.electricity_peak_rate.value = settings.electricity_peak_rate ?? 0;
    settingsForm.elements.electricity_offpeak_rate.value = settings.electricity_offpeak_rate ?? 0;
    settingsForm.elements.electricity_offpeak_start.value = settings.electricity_offpeak_start ?? "22:00";
    settingsForm.elements.electricity_offpeak_end.value = settings.electricity_offpeak_end ?? "07:00";
    settingsForm.elements.show_main_shortcut.checked = Boolean(settings.show_main_shortcut);
    applyTariffMode(settingsForm.elements.electricity_tariff_mode.value);
  }

  function openSettings() {
    populateSettingsForm(currentSettings);
    settingsShell.hidden = false;
  }

  function closeSettings() {
    settingsShell.hidden = true;
  }

  function tooltipAttr(payload) {
    return `data-dt-tooltip="${escapeHtml(encodeURIComponent(JSON.stringify(payload)))}"`;
  }

  function renderTooltipPayload(payload) {
    const items = Array.isArray(payload.items) ? payload.items : [];
    return `
      <div class="dt-tooltip-title">${escapeHtml(payload.title || "")}</div>
      <div class="dt-tooltip-items">
        ${items.map((item) => `
          <div class="dt-tooltip-item">
            <div class="dt-tooltip-item-main">
              ${item.color ? `<span class="dt-history-swatch" style="background:${escapeHtml(item.color)}"></span>` : ""}
              <span class="dt-tooltip-item-label">${escapeHtml(item.label || "")}</span>
            </div>
            <div class="dt-tooltip-item-value">${escapeHtml(item.value || "")}</div>
          </div>
        `).join("")}
      </div>
    `;
  }

  function hideTooltip() {
    tooltip.hidden = true;
    tooltip.innerHTML = "";
  }

  function positionTooltip(event) {
    const offset = 14;
    const rect = tooltip.getBoundingClientRect();
    let left = event.clientX + offset;
    let top = event.clientY + offset;
    if (left + rect.width > window.innerWidth - 12) {
      left = event.clientX - rect.width - offset;
    }
    if (top + rect.height > window.innerHeight - 12) {
      top = event.clientY - rect.height - offset;
    }
    tooltip.style.left = `${Math.max(12, left)}px`;
    tooltip.style.top = `${Math.max(12, top)}px`;
  }

  function showTooltip(event, target) {
    const raw = target.getAttribute("data-dt-tooltip");
    if (!raw) {
      hideTooltip();
      return;
    }
    try {
      const payload = JSON.parse(decodeURIComponent(raw));
      tooltip.innerHTML = renderTooltipPayload(payload);
      tooltip.hidden = false;
      positionTooltip(event);
    } catch (error) {
      hideTooltip();
    }
  }

  function hashString(value) {
    let hash = 0;
    const text = String(value || "");
    for (let index = 0; index < text.length; index += 1) {
      hash = ((hash << 5) - hash) + text.charCodeAt(index);
      hash |= 0;
    }
    return Math.abs(hash);
  }

  function normalizePercent(value) {
    const numeric = Number(value);
    return Number.isFinite(numeric) ? Math.max(0, numeric) : 0;
  }

  function humanPercent(value) {
    const numeric = normalizePercent(value);
    if (numeric <= 0) {
      return "0%";
    }
    if (numeric < 10) {
      return `${numeric.toFixed(1)}%`;
    }
    return `${numeric.toFixed(0)}%`;
  }

  function formatLocalDateTime(value) {
    if (!value) {
      return "-";
    }
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) {
      return "-";
    }
    return date.toLocaleString([], {
      month: "short",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit"
    });
  }

  function renderTemperatureSparkline(temperature) {
    const points = ((temperature && temperature.points) || []).filter((point) => Number.isFinite(Number(point.value_c)));
    if (!points.length) {
      return '<span class="dt-empty">-</span>';
    }

    const width = 118;
    const height = 28;
    const paddingX = 2;
    const paddingY = 3;
    const values = points.map((point) => Number(point.value_c));
    const min = Math.min(...values);
    const max = Math.max(...values);
    const range = Math.max(max - min, 1);
    const lastIndex = Math.max(points.length - 1, 1);
    const coords = points.map((point, index) => {
      const x = paddingX + ((width - (paddingX * 2)) * (points.length === 1 ? 0.5 : (index / lastIndex)));
      const y = paddingY + ((height - (paddingY * 2)) * (1 - ((Number(point.value_c) - min) / range)));
      return { x, y, point };
    });
    const linePath = coords.map((point, index) => `${index === 0 ? "M" : "L"} ${point.x.toFixed(2)} ${point.y.toFixed(2)}`).join(" ");
    const areaPath = `M ${coords[0].x.toFixed(2)} ${(height - paddingY).toFixed(2)} ${coords.map((point) => `L ${point.x.toFixed(2)} ${point.y.toFixed(2)}`).join(" ")} L ${coords[coords.length - 1].x.toFixed(2)} ${(height - paddingY).toFixed(2)} Z`;
    const lastPoint = coords[coords.length - 1];

    return `
      <svg class="dt-temp-spark" viewBox="0 0 ${width} ${height}" aria-hidden="true">
        <path class="track" d="M ${paddingX} ${(height - paddingY).toFixed(2)} L ${(width - paddingX).toFixed(2)} ${(height - paddingY).toFixed(2)}"></path>
        <path class="area" d="${areaPath}"></path>
        <path class="line" d="${linePath}"></path>
        <circle class="point" cx="${lastPoint.x.toFixed(2)}" cy="${lastPoint.y.toFixed(2)}" r="2.8"></circle>
      </svg>
    `;
  }

  function renderTemperatureCell(disk, history) {
    const current = disk.temperature_human || "-";
    const temperature = history && history.temperature ? history.temperature : null;
    const range = temperature && temperature.min_c != null && temperature.max_c != null
      ? `${escapeHtml(temperature.min_human || "-")} - ${escapeHtml(temperature.max_human || "-")}`
      : "No history";
    return `
      <div class="dt-temp-wrap">
        <div class="dt-temp-row">
          <span class="dt-temp-value">${escapeHtml(current)}</span>
          <span class="dt-temp-range">${range}</span>
        </div>
        ${renderTemperatureSparkline(temperature)}
      </div>
    `;
  }

  function isUnattributedTalker(talker) {
    const name = (talker && talker.name ? talker.name : "").toLowerCase();
    const id = talker && talker.id ? talker.id : "";
    return id.includes("Unknown") || name === "unknown" || name.includes("unattributed");
  }

  function visibleTalkerName(talker) {
    return isUnattributedTalker(talker) ? "Other activity" : (talker.name || "");
  }

  function talkerColor(talker) {
    if (!talker) {
      return "#526073";
    }
    if (isUnattributedTalker(talker)) {
      return "#5d6878";
    }
    return chartPalette[hashString(talker.id || talker.name) % chartPalette.length];
  }

  function buildChartSegments(talkers, includeRemainder = true) {
    const segments = [];
    let consumed = 0;
    (talkers || []).forEach((talker) => {
      const percent = normalizePercent(talker.percent);
      if (percent <= 0) {
        return;
      }
      if (isUnattributedTalker(talker)) {
        return;
      }
      consumed += percent;
      segments.push({ ...talker, name: visibleTalkerName(talker), percent, color: talkerColor(talker) });
    });

    const remainder = Math.max(0, 100 - consumed);
    if (includeRemainder && remainder > 0.35) {
      segments.push({
        id: "remainder",
        name: "Other activity",
        percent: remainder,
        percent_human: `${remainder.toFixed(remainder >= 10 ? 0 : 1)}%`,
        duration_human: "",
        color: "#232d39"
      });
    }

    return segments;
  }

  function renderDonutChart(segments, centerValue, centerLabel, size = 116, stroke = 12) {
    const radius = (size - stroke) / 2;
    const circumference = 2 * Math.PI * radius;
    let offset = 0;
    const rings = (segments || []).map((segment) => {
      const length = Math.max(0, Math.min(segment.percent, 100)) / 100 * circumference;
      const tooltipPayload = {
        title: segment.name,
        items: [
          {
            label: "Share",
            value: segment.percent_human || humanPercent(segment.percent || 0),
            color: segment.color
          },
          ...(segment.duration_human ? [{ label: "Time", value: segment.duration_human, color: segment.color }] : [])
        ]
      };
      const circle = `
        <circle
          class="dt-history-chart-segment"
          cx="${size / 2}"
          cy="${size / 2}"
          r="${radius}"
          stroke="${escapeHtml(segment.color)}"
          stroke-width="${stroke}"
          stroke-dasharray="${length} ${Math.max(circumference - length, 0)}"
          stroke-dashoffset="${-offset}"
          ${tooltipAttr(tooltipPayload)}
        ></circle>
      `;
      offset += length;
      return circle;
    }).join("");

    return `
      <div class="dt-history-chart">
        <div class="dt-history-chart-wrap">
          <svg class="dt-history-chart-svg" viewBox="0 0 ${size} ${size}" aria-hidden="true">
            <circle class="dt-history-chart-track" cx="${size / 2}" cy="${size / 2}" r="${radius}" stroke-width="${stroke}"></circle>
            ${rings}
          </svg>
          <div class="dt-history-center">
            <div class="dt-history-center-value">${escapeHtml(centerValue || "0%")}</div>
            <div class="dt-history-center-label">${escapeHtml(centerLabel || "-")}</div>
          </div>
        </div>
      </div>
    `;
  }

  function renderHistoryLegendItem(talker) {
    return `
      <div class="dt-history-item">
        <div class="dt-history-item-main">
          <span class="dt-history-swatch" style="background:${escapeHtml(talker.color)}"></span>
          <span class="dt-history-item-name">${escapeHtml(talker.name)}</span>
        </div>
        <div class="dt-history-item-meta">${escapeHtml(talker.percent_human || "0%")}${talker.duration_human ? ` · ${escapeHtml(talker.duration_human)}` : ""}</div>
      </div>
    `;
  }

  function renderSpinupSessions(sessions) {
    if (!sessions || !sessions.length) {
      return `
        <div class="dt-history-sessions">
          <div class="dt-history-sessions-head">Spin-up sessions</div>
          <div class="dt-history-sessions-note">No spin-up starts recorded in this window yet.</div>
        </div>
      `;
    }

    const rows = sessions.map((session) => {
      const trigger = session.trigger_talker || {};
      const sourceMeta = session.active ? '<span class="dt-session-active">Running</span>' : '';
      const files = (session.trigger_paths || []).length
        ? `<div class="dt-session-files">${session.trigger_paths.map((path) => `<div class="dt-session-file">${escapeHtml(path)}</div>`).join("")}</div>`
        : '<span class="dt-empty">-</span>';
      return `
        <tr>
          <td class="dt-session-time">${escapeHtml(formatLocalDateTime(session.started_at))}</td>
          <td class="dt-session-duration">${escapeHtml(session.duration_human || "-")}</td>
          <td>
            <div class="dt-session-source">
              ${iconHtml(trigger.icon, trigger.name || "Service")}
              <span class="dt-session-source-name">${escapeHtml(trigger.name || "Other activity")}</span>
            </div>
            ${sourceMeta ? `<div class="dt-session-source-meta">${sourceMeta}</div>` : ""}
          </td>
          <td>${files}</td>
        </tr>
      `;
    }).join("");

    return `
      <div class="dt-history-sessions">
        <div class="dt-history-sessions-head">Spin-up sessions</div>
        <div class="dt-history-sessions-note">Latest session starts in this ${escapeHtml(selectedPeriod)} window.</div>
        <table class="dt-session-table">
          <thead>
            <tr>
              <th style="width:124px">Started</th>
              <th style="width:86px">Duration</th>
              <th style="width:190px">Source</th>
              <th>Files at spin-up</th>
            </tr>
          </thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
    `;
  }

  function renderTalker(disk, talker, detailKey) {
    const pidDetails = talker.pid_details || [];
    let subtitle = "";
    if (pidDetails.length === 1) {
      subtitle = `PID ${escapeHtml(pidDetails[0].pid)} · R ~${escapeHtml(pidDetails[0].estimated_read_human || "-")}`;
    } else if (pidDetails.length > 1) {
      subtitle = `${escapeHtml(pidDetails.length)} PIDs · R ~${escapeHtml(talker.estimated_read_human || "-")}`;
    } else if (talker.pids && talker.pids.length) {
      subtitle = `PID ${escapeHtml(talker.pids.join(", "))}`;
    }
    return `
      <button
        type="button"
        class="dt-talker dt-talker-btn ${talker.active ? "active" : "recent"}"
        data-detail-key="${escapeHtml(detailKey)}"
        title="Click for details"
      >
        ${iconHtml(talker.icon, talker.name)}
        <span>
          <div class="dt-talker-name">${escapeHtml(talker.name)}</div>
          ${subtitle ? `<div class="dt-pids">${subtitle}</div>` : ""}
        </span>
      </button>
    `;
  }

  function renderHistoryBlock(history, activePeriod) {
    if (!history) {
      return `
        <div class="dt-history">
          <div class="dt-history-head">${escapeHtml(periodLabel(activePeriod))}</div>
          <div class="dt-empty">-</div>
        </div>
      `;
    }

    const talkers = buildChartSegments(history.top_talkers || []);
    return `
      <div class="dt-history">
        <div class="dt-history-head">${escapeHtml(periodLabel(activePeriod))} history</div>
        <div class="dt-history-summary">Spun up ${escapeHtml(history.spun_up_percent_human || "0%")} · ${escapeHtml(history.spun_up_human || "-")}</div>
        <div class="dt-history-layout">
          ${renderDonutChart(talkers, history.spun_up_percent_human || "0%", history.spun_up_human || "-")}
            <div class="dt-history-list">
            ${talkers.length ? talkers.map(renderHistoryLegendItem).join("") : '<div class="dt-empty">No clear usage source yet</div>'}
          </div>
        </div>
        ${renderSpinupSessions(history.sessions || [])}
      </div>
    `;
  }

  function timelineTooltipPayload(point) {
    const items = [
      {
        label: "Avg disks up",
        value: point.avg_spun_up_disks_human || "0.0"
      }
    ];
    if (point.top_talkers && point.top_talkers.length) {
      point.top_talkers.forEach((talker) => {
        items.push({
          label: visibleTalkerName(talker),
          value: `${talker.percent_human || "0%"}${talker.duration_human ? ` · ${talker.duration_human}` : ""}`,
          color: talkerColor(talker)
        });
      });
    } else {
      items.push({
        label: "Usage",
        value: "No array activity"
      });
    }
    return {
      title: point.label || "",
      items
    };
  }

  function renderTimeline(periodSummary, activePeriod) {
    const timeline = periodSummary.timeline || { points: [], max_spun_up_disks: 0 };
    const points = timeline.points || [];
    if (!points.length) {
      return `
        <div class="dt-timeline-shell">
          <div class="dt-summary-panel-head">
            <div>
              <div class="dt-summary-kicker">Array spin-up timeline</div>
              <div class="dt-summary-panel-note">No history points yet for the selected window.</div>
            </div>
          </div>
        </div>
      `;
    }

    const width = 660;
    const height = 224;
    const padding = { top: 14, right: 10, bottom: 48, left: 10 };
    const innerWidth = width - padding.left - padding.right;
    const innerHeight = height - padding.top - padding.bottom;
    const baseY = padding.top + innerHeight;
    const maxValue = Math.max(1, Number(timeline.max_spun_up_disks || 0), ...points.map((point) => Number(point.avg_spun_up_disks || 0)));
    const coords = points.map((point, index) => {
      const ratio = points.length === 1 ? 0.5 : index / (points.length - 1);
      const x = padding.left + (ratio * innerWidth);
      const value = Number(point.avg_spun_up_disks || 0);
      const y = padding.top + (innerHeight - ((value / maxValue) * innerHeight));
      const dominantTalker = (point.top_talkers || []).find((talker) => !isUnattributedTalker(talker)) || (point.top_talkers || [])[0] || null;
      return {
        ...point,
        value,
        x,
        y,
        dominantColor: dominantTalker ? talkerColor(dominantTalker) : "#526073"
      };
    });

    const linePath = coords.map((point, index) => `${index === 0 ? "M" : "L"} ${point.x.toFixed(2)} ${point.y.toFixed(2)}`).join(" ");
    const areaPath = coords.length
      ? `M ${coords[0].x.toFixed(2)} ${baseY.toFixed(2)} ${coords.map((point) => `L ${point.x.toFixed(2)} ${point.y.toFixed(2)}`).join(" ")} L ${coords[coords.length - 1].x.toFixed(2)} ${baseY.toFixed(2)} Z`
      : "";
    const gridLines = [0, 0.25, 0.5, 0.75, 1].map((step) => {
      const y = padding.top + ((1 - step) * innerHeight);
      return `<line class="dt-timeline-grid-line" x1="${padding.left}" x2="${width - padding.right}" y1="${y.toFixed(2)}" y2="${y.toFixed(2)}"></line>`;
    }).join("");
    const labelStep = Math.max(1, Math.ceil(points.length / 7));
    const labels = coords.map((point, index) => {
      if (index !== 0 && index !== coords.length - 1 && (index % labelStep !== 0)) {
        return "";
      }
      return `<text class="dt-timeline-axis-label" x="${point.x.toFixed(2)}" y="${(height - 10).toFixed(2)}" text-anchor="middle">${escapeHtml(point.short_label || point.label || "")}</text>`;
    }).join("");
    const bars = coords.map((point, index) => {
      const startX = index === 0 ? padding.left : (coords[index - 1].x + point.x) / 2;
      const endX = index === coords.length - 1 ? width - padding.right : (point.x + coords[index + 1].x) / 2;
      return `
        <rect
          class="dt-timeline-bar"
          x="${startX.toFixed(2)}"
          y="${(baseY + 12).toFixed(2)}"
          width="${Math.max(2, endX - startX).toFixed(2)}"
          height="8"
          rx="4"
          fill="${escapeHtml(point.dominantColor)}"
          ${tooltipAttr(timelineTooltipPayload(point))}
        ></rect>
      `;
    }).join("");
    const pointsMarkup = coords.map((point) => `
      <circle
        class="dt-timeline-point"
        cx="${point.x.toFixed(2)}"
        cy="${point.y.toFixed(2)}"
        r="5.5"
        fill="${escapeHtml(point.dominantColor)}"
        ${tooltipAttr(timelineTooltipPayload(point))}
      ></circle>
    `).join("");

    return `
      <div class="dt-timeline-shell">
        <div class="dt-summary-panel-head">
          <div>
            <div class="dt-summary-kicker">Array spin-up timeline</div>
            <div class="dt-summary-panel-note">${escapeHtml(periodLabel(activePeriod))} view. Height tracks average disks up; point color tracks the dominant usage source.</div>
          </div>
          <div class="dt-summary-panel-meta">Peak ${escapeHtml(timeline.max_spun_up_disks_human || "0.0")} disks up</div>
        </div>
        <div class="dt-timeline-card">
          <svg class="dt-timeline-svg" viewBox="0 0 ${width} ${height}" role="img" aria-label="Array spin-up timeline">
            <defs>
              <linearGradient id="dtTimelineFill" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#74b7ff" stop-opacity="0.34"></stop>
                <stop offset="100%" stop-color="#74b7ff" stop-opacity="0.02"></stop>
              </linearGradient>
            </defs>
            ${gridLines}
            ${areaPath ? `<path class="dt-timeline-area" d="${areaPath}"></path>` : ""}
            ${linePath ? `<path class="dt-timeline-line" d="${linePath}"></path>` : ""}
            ${pointsMarkup}
            ${bars}
            ${labels}
          </svg>
        </div>
      </div>
    `;
  }

  function renderAuditCard(item) {
    return `
      <div class="dt-audit-card">
        <div class="dt-audit-head">
          <span class="dt-audit-app">
            ${iconHtml(item.icon, item.name)}
            <span>
              <div class="dt-audit-name">${escapeHtml(item.name)}</div>
              <div class="dt-audit-status">${escapeHtml(item.status || "unknown")}</div>
            </span>
          </span>
          <span class="dt-audit-actions">
            ${item.config_url ? `<a class="dt-audit-link" href="${escapeHtml(item.config_url)}" title="Open container configuration">Config <i class="fa fa-external-link"></i></a>` : ""}
            <span class="dt-audit-badge ${escapeHtml(item.severity)}">${escapeHtml(item.severity)}</span>
          </span>
        </div>
        <div class="dt-audit-mounts">
          ${(item.mounts || []).map((mount) => `
            <div class="dt-audit-mount">
              <div class="dt-audit-path">${escapeHtml(mount.source)} → ${escapeHtml(mount.target || "-")}</div>
              <div class="dt-audit-note">${escapeHtml(mount.label)} · ${escapeHtml(mount.reason)}</div>
            </div>
          `).join("")}
        </div>
      </div>
    `;
  }

  function renderPidCard(pidDetail) {
    return `
      <div class="dt-detail-card">
        <div class="dt-detail-card-title">PID ${escapeHtml(pidDetail.pid)}</div>
        <div class="dt-detail-card-subtitle">${pidDetail.active ? "Active now" : "Recent only"}</div>
        <div class="dt-detail-section">
          <div class="dt-detail-section-label">Estimated On This Disk</div>
          <div class="dt-detail-value">Read ${escapeHtml(pidDetail.estimated_read_human || "-")} · Write ${escapeHtml(pidDetail.estimated_write_human || "-")}</div>
        </div>
        <div class="dt-detail-section">
          <div class="dt-detail-section-label">Process I/O</div>
          <div class="dt-detail-value">Read ${escapeHtml(pidDetail.process_read_human || "-")} · Write ${escapeHtml(pidDetail.process_write_human || "-")}</div>
        </div>
        <div class="dt-detail-section">
          <div class="dt-detail-section-label">Open Now</div>
          ${renderPathList(pidDetail.open_paths || [])}
        </div>
        <div class="dt-detail-section">
          <div class="dt-detail-section-label">Recent On This Disk</div>
          ${renderPathList(pidDetail.recent_paths || [])}
        </div>
      </div>
    `;
  }

  function openDetail(detailKey) {
    const detail = detailStore.get(detailKey);
    if (!detail) {
      return;
    }

    const { disk, talker } = detail;
    modalTitle.textContent = talker.name;
    modalSubtitle.textContent = `${disk.name} · ${talker.active ? "active" : "recent"} talker`;
    modalBody.innerHTML = `
      <div class="dt-detail-meta">
        <div class="dt-detail-pill">
          <div class="dt-detail-label">Disk Read</div>
          <div class="dt-detail-value">${escapeHtml(disk.rates && disk.rates.read_human ? disk.rates.read_human : "-")}</div>
        </div>
        <div class="dt-detail-pill">
          <div class="dt-detail-label">Disk Write</div>
          <div class="dt-detail-value">${escapeHtml(disk.rates && disk.rates.write_human ? disk.rates.write_human : "-")}</div>
        </div>
        <div class="dt-detail-pill">
          <div class="dt-detail-label">Talker Estimate</div>
          <div class="dt-detail-value">Read ${escapeHtml(talker.estimated_read_human || "-")} · Write ${escapeHtml(talker.estimated_write_human || "-")}</div>
        </div>
        <div class="dt-detail-pill">
          <div class="dt-detail-label">Events</div>
          <div class="dt-detail-value">${escapeHtml(talker.event_count || 0)}</div>
        </div>
      </div>
      <div class="dt-detail-section">
        <div class="dt-detail-section-label">Recent Disk Paths</div>
        ${renderPathList(talker.paths || [])}
      </div>
      <div class="dt-detail-section">
        <div class="dt-detail-section-label">PID Details</div>
        <div class="dt-detail-grid">
          ${(talker.pid_details && talker.pid_details.length) ? talker.pid_details.map(renderPidCard).join("") : '<div class="dt-empty">-</div>'}
        </div>
      </div>
    `;
    modalShell.hidden = false;
  }

  function closeDetail() {
    modalShell.hidden = true;
  }

  async function requestControl(action, button, confirmText) {
    const proceed = await confirmDialog("Proceed?", confirmText);
    if (!proceed) {
      return;
    }

    setButtonBusy(button, true);
    try {
      const body = new URLSearchParams({
        action,
        csrf_token
      });
      const response = await fetch(controlEndpoint, {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8" },
        body: body.toString()
      });
      const payload = await response.json();
      if (!response.ok || !payload.ok) {
        throw new Error(payload.error || "Action failed.");
      }
      showToast(payload.message || "Action requested.", "success");
      window.setTimeout(refresh, 1200);
    } catch (error) {
      showToast(error.message || "Action failed.", "error");
    } finally {
      setButtonBusy(button, false);
    }
  }

  async function saveSettings(event) {
    event.preventDefault();
    const formData = new FormData(settingsForm);
    formData.set("csrf_token", csrf_token);
    formData.set("show_main_shortcut", settingsForm.elements.show_main_shortcut.checked ? "1" : "0");

    setButtonBusy(settingsSave, true);
    try {
      const response = await fetch(settingsEndpoint, {
        method: "POST",
        body: new URLSearchParams(formData)
      });
      const payload = await response.json();
      if (!response.ok || !payload.ok) {
        throw new Error(payload.error || "Failed to save settings.");
      }
      currentSettings = payload.settings || currentSettings;
      populateSettingsForm(currentSettings);
      showToast("Settings saved.", "success");
      closeSettings();
      window.setTimeout(refresh, 1400);
    } catch (error) {
      showToast(error.message || "Failed to save settings.", "error");
    } finally {
      setButtonBusy(settingsSave, false);
    }
  }

  function render(payload) {
    if (!payload.ok) {
      applyDependencyBlocked(false);
      meta.textContent = "Collector unavailable";
      renderNotices([{ tone: "error", message: payload.error || "Unknown error" }]);
      summary.innerHTML = "";
      auditCount = 0;
      applyAuditVisibility();
      auditBody.innerHTML = "";
      root.innerHTML = `<div class="dt-error">${escapeHtml(payload.error || "Unknown error")}</div>`;
      return;
    }

    const noticesToRender = [];
    if (payload.dependency_blocked && payload.dependency && payload.dependency.name) {
      noticesToRender.push({
        tone: "warning",
        message: `Disk Talkers needs ${payload.dependency.name} before the collector can run.`
      });
    }
    if (payload.initializing) {
      noticesToRender.push({
        tone: "info",
        message: "Collector is starting. Disk data should appear within a few seconds."
      });
    }
    (payload.warnings || []).forEach((warning) => {
      noticesToRender.push({ tone: "warning", message: warning });
    });
    renderNotices(noticesToRender);

    currentSettings = payload.settings || currentSettings;
    if (currentSettings && settingsShell.hidden) {
      populateSettingsForm(currentSettings);
    }

    if (payload.dependency_blocked) {
      applyDependencyBlocked(true);
      meta.textContent = "Dependency required";
      root.innerHTML = renderDependencyBlocked(payload);
      return;
    }

    applyDependencyBlocked(false);

    const history = payload.history || { default_period: "daily", periods: {} };
    if (!periodOptions.includes(selectedPeriod)) {
      selectedPeriod = history.default_period || "daily";
    }

    const refreshSeconds = currentSettings && currentSettings.poll_interval ? currentSettings.poll_interval : 5;
    meta.textContent = `Refresh: every ${escapeHtml(refreshSeconds)}s`;
    detailStore.clear();
    renderPeriodButtons(selectedPeriod);

    const mountAudit = payload.mount_audit || [];
    auditCount = mountAudit.length;
    applyAuditVisibility();
    auditBody.innerHTML = `
      <div class="dt-audit-list">
        ${mountAudit.length ? mountAudit.map(renderAuditCard).join("") : '<span class="dt-empty">-</span>'}
      </div>
    `;

    const periodSummary = (history.periods || {})[selectedPeriod] || { avg_spun_up_disks_human: "0.0", top_array_talkers: [], disks: {} };
    const summarySegments = buildChartSegments(periodSummary.top_array_talkers || []);
    const power = periodSummary.power || {};
    const costConfigured = Number(power.cost_max || 0) > 0 || Number(power.cost_min || 0) > 0;
    summary.innerHTML = `
      <div class="dt-summary-title">Historical array usage</div>
      <div class="dt-summary-shell">
        <div class="dt-summary-stat">
          <div class="dt-summary-kicker">${escapeHtml(periodLabel(selectedPeriod))} period</div>
          <div class="dt-summary-value-row">
            <div class="dt-summary-value">${escapeHtml(periodSummary.avg_spun_up_disks_human || "0.0")}</div>
            <div class="dt-summary-unit">disks avg</div>
          </div>
          <div class="dt-summary-sub">Average array disks spun up across this window.</div>
          <div class="dt-summary-metrics">
            <div class="dt-summary-metric">
              <div class="dt-summary-metric-label">Total HDD up time</div>
              <div class="dt-summary-metric-value">${escapeHtml(periodSummary.total_spun_up_human || "-")}</div>
              <div class="dt-summary-metric-note">${escapeHtml(periodSummary.disk_hours_human || "0.0 disk-hours")}</div>
            </div>
            <div class="dt-summary-metric">
              <div class="dt-summary-metric-label">Estimated energy</div>
              <div class="dt-summary-metric-value">${escapeHtml((power.energy_min_human || "0 Wh"))} - ${escapeHtml((power.energy_max_human || "0 Wh"))}</div>
              <div class="dt-summary-metric-note">${escapeHtml(power.assumption_human || "Estimated with a generic spun-up HDD range.")}</div>
            </div>
            <div class="dt-summary-metric">
              <div class="dt-summary-metric-label">Estimated cost</div>
              <div class="dt-summary-metric-value">${costConfigured ? `${escapeHtml(power.cost_min_human || "")} - ${escapeHtml(power.cost_max_human || "")}` : "Set tariff in Settings"}</div>
              <div class="dt-summary-metric-note">${escapeHtml(power.tariff_note_human || "Add your electricity rate to estimate cost.")}</div>
            </div>
          </div>
        </div>
        <div class="dt-summary-chart-panel">
          <div class="dt-summary-panel-head">
            <div>
              <div class="dt-summary-kicker">Main usage sources</div>
              <div class="dt-summary-panel-note">Attributed from live talkers sampled while array disks were up.</div>
            </div>
            <div class="dt-summary-panel-meta">${escapeHtml(periodSummary.disk_hours_human || "0.0 disk-hours")}</div>
          </div>
          <div class="dt-summary-chart-grid">
            ${renderDonutChart(summarySegments, periodSummary.avg_spun_up_disks_human || "0.0", "avg disks up", 136, 14)}
            <div>
              <div class="dt-history-list" style="margin-top:2px">
                ${summarySegments.length ? summarySegments.map(renderHistoryLegendItem).join("") : '<div class="dt-empty">No clear array usage source recorded yet</div>'}
              </div>
              <div class="dt-summary-caption">Historical usage attribution is estimated from the talkers observed in each sample window.</div>
            </div>
          </div>
        </div>
        <div class="dt-summary-timeline-panel">
          ${renderTimeline(periodSummary, selectedPeriod)}
        </div>
      </div>
    `;

    const rows = (payload.disks || []).map((disk) => {
      const talkers = disk.talkers || [];
      const readRate = disk.rates && disk.rates.read_human ? disk.rates.read_human : "-";
      const writeRate = disk.rates && disk.rates.write_human ? disk.rates.write_human : "-";
      const historyForDisk = periodSummary.disks ? periodSummary.disks[disk.id] : null;
      const talkerHtml = talkers.length ? talkers.map((talker) => {
        const detailKey = `${disk.id}::${talker.id}`;
        detailStore.set(detailKey, { disk, talker });
        return renderTalker(disk, talker, detailKey);
      }).join("") : '<span class="dt-empty">-</span>';
      return `
        <tr>
          <td class="dt-col-disk"><div class="dt-disk">${escapeHtml(disk.name)}</div></td>
          <td class="dt-col-status">
            <span class="dt-status ${escapeHtml(disk.status.state)}">${escapeHtml(disk.status.label)}</span>
          </td>
          <td class="dt-col-temp">${renderTemperatureCell(disk, historyForDisk)}</td>
          <td class="dt-col-rate"><span class="dt-rate">${escapeHtml(readRate)}</span></td>
          <td class="dt-col-rate"><span class="dt-rate">${escapeHtml(writeRate)}</span></td>
          <td>
            <div class="dt-talkers">
              ${talkerHtml}
            </div>
            ${disk.kind === "disk" ? renderHistoryBlock(historyForDisk, selectedPeriod) : ""}
          </td>
        </tr>
      `;
    }).join("");

    if (payload.initializing && !(payload.disks || []).length) {
      root.innerHTML = '<div class="dt-empty-panel">Collector is starting. If this stays empty for more than a few seconds, check <code>/var/log/disk.talkers.log</code> on the Unraid host.</div>';
      return;
    }

    root.innerHTML = `
      <table class="dt-table">
        <thead>
          <tr>
            <th class="dt-col-disk">Disk</th>
            <th class="dt-col-status">Status</th>
            <th class="dt-col-temp">Temp</th>
            <th class="dt-col-rate">Read</th>
            <th class="dt-col-rate">Write</th>
            <th>Disk users</th>
          </tr>
        </thead>
        <tbody>${rows}</tbody>
      </table>
    `;
  }

  async function refresh() {
    try {
      const response = await fetch(endpoint, { cache: "no-store" });
      const payload = await response.json();
      render(payload);
    } catch (error) {
      meta.textContent = "Refresh failed";
      renderNotices([{ tone: "error", message: error.message || "Unknown error" }]);
      root.innerHTML = `<div class="dt-error">${escapeHtml(error.message || "Unknown error")}</div>`;
    }
  }

  root.addEventListener("click", (event) => {
    const button = event.target.closest("[data-detail-key]");
    if (!button) {
      return;
    }
    openDetail(button.getAttribute("data-detail-key"));
  });

  periods.addEventListener("click", (event) => {
    const button = event.target.closest("[data-period]");
    if (!button) {
      return;
    }
    selectedPeriod = button.getAttribute("data-period") || "daily";
    localStorage.setItem("dt-history-period", selectedPeriod);
    refresh();
  });

  auditToggle.addEventListener("click", () => {
    auditOpen = !auditOpen;
    localStorage.setItem("dt-audit-open", auditOpen ? "1" : "0");
    applyAuditVisibility();
  });

  spinUpAllButton.addEventListener("click", () => {
    requestControl("spinup_all", spinUpAllButton, "This will immediately spin up all array disks.");
  });

  spinDownAllButton.addEventListener("click", () => {
    requestControl("spindown_all", spinDownAllButton, "This will immediately spin down all array disks.");
  });

  settingsOpenButton.addEventListener("click", openSettings);
  settingsClose.addEventListener("click", closeSettings);
  settingsCancel.addEventListener("click", closeSettings);
  settingsForm.addEventListener("submit", saveSettings);
  tariffModeInput.addEventListener("change", (event) => {
    applyTariffMode(event.target.value);
  });

  modalShell.addEventListener("click", (event) => {
    if (event.target.closest("[data-dt-close='1']")) {
      closeDetail();
    }
  });

  settingsShell.addEventListener("click", (event) => {
    if (event.target.closest("[data-dt-settings-close='1']")) {
      closeSettings();
    }
  });

  modalClose.addEventListener("click", closeDetail);
  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && !modalShell.hidden) {
      closeDetail();
    }
    if (event.key === "Escape" && !settingsShell.hidden) {
      closeSettings();
    }
  });
  document.addEventListener("mouseover", (event) => {
    const target = event.target.closest("[data-dt-tooltip]");
    if (!target) {
      hideTooltip();
      return;
    }
    showTooltip(event, target);
  });
  document.addEventListener("mousemove", (event) => {
    if (!tooltip.hidden) {
      positionTooltip(event);
    }
  });
  document.addEventListener("mouseout", (event) => {
    const target = event.target.closest("[data-dt-tooltip]");
    if (!target) {
      return;
    }
    const next = event.relatedTarget && event.relatedTarget.closest ? event.relatedTarget.closest("[data-dt-tooltip]") : null;
    if (next === target) {
      return;
    }
    hideTooltip();
  });
  window.addEventListener("scroll", hideTooltip, true);

  renderPeriodButtons(selectedPeriod);
  applyAuditVisibility();
  applyHostTheme();
  refresh();
  window.setInterval(refresh, 5000);
})();
</script>
